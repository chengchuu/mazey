{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2015",
    "module": "ESNext",
    "lib": ["es5", "DOM", "ScriptHost", "ESNext"],
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "importHelpers": true,
    "strict": true,
    "noImplicitThis": false,
    "moduleResolution": "bundler",
    "paths": {
      "tslib" : ["./node_modules/tslib/tslib.d.ts"]
    },
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["global"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./src/**/*.ts",
    "./types/**/*.ts"
  ],
  "typedocOptions": {
    "entryPoints": ["./src"],
    "out": "./docs",
    "excludeNotDocumented": true,
    "excludeNotDocumentedKinds": ["Property", "Interface", "TypeAlias"],
    "validation": {
      "notExported": false,
      "notDocumented": false
    },
    "categoryOrder": [
      "Load Resource",
      "Util",
      "URL",
      "Cache Data",
      "DOM",
      "Calculate and Formula",
      "Browser Information",
      "Event",
      "Web Performance",
      "Debug"
    ]
  }
}
